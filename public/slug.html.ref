		<div class="elementor-element elementor-element-56caf648 e-con-full e-flex e-con e-parent e-lazyloaded" data-id="56caf648" data-element_type="container" data-e-type="container" id="footer-two-photos" data-settings="{&quot;background_background&quot;:&quot;classic&quot;}">
